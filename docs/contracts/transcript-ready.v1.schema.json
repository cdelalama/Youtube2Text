{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://media2text.local/contracts/transcript-ready.v1.schema.json",
  "title": "Media2Text Transcript Ready v1",
  "description": "Draft producer-owned event contract for immutable transcript availability and source-authority withdrawals. Delivery is at-least-once.",
  "x-contract-status": "draft-consumer-re-review-required",
  "type": "object",
  "required": ["schemaVersion", "eventType", "eventId", "idempotencyKey", "occurredAt", "correlation", "source", "transcript", "lifecycle"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "media2text.transcript-ready.v1" },
    "eventType": { "enum": ["transcript.ready", "transcript.withdrawn"] },
    "eventId": { "type": "string", "pattern": "^evt_[a-f0-9]{64}$" },
    "idempotencyKey": { "type": "string", "minLength": 1 },
    "occurredAt": { "type": "string", "format": "date-time" },
    "correlation": {
      "type": "object",
      "required": ["runId"],
      "additionalProperties": false,
      "properties": {
        "runId": { "type": "string", "minLength": 1 },
        "intakeId": {
          "oneOf": [
            { "type": "string", "pattern": "^int_[a-f0-9]{64}$" },
            { "type": "null" }
          ]
        }
      }
    },
    "source": {
      "oneOf": [
        { "$ref": "transcript-store.v1.schema.json#/$defs/source" },
        { "$ref": "transcript-store.v2.schema.json#/$defs/source" }
      ]
    },
    "transcript": {
      "type": "object",
      "required": ["transcriptId", "recordSha256", "recordBytes", "schemaVersion", "href"],
      "additionalProperties": false,
      "properties": {
        "transcriptId": { "type": "string", "pattern": "^trn_[a-f0-9]{64}$" },
        "recordSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "recordBytes": { "type": "integer", "minimum": 1 },
        "schemaVersion": { "enum": ["media2text.transcript.v1", "media2text.transcript.v2"] },
        "href": { "type": "string", "pattern": "^/v1/transcripts/trn_[a-f0-9]{64}$" }
      }
    },
    "lifecycle": {
      "type": "object",
      "required": ["revision", "revisionReason", "status", "current", "supersedesTranscriptId", "supersededByTranscriptId"],
      "additionalProperties": false,
      "properties": {
        "revision": { "type": "integer", "minimum": 1 },
        "revisionReason": { "enum": ["initial", "retranscription", "source-revision"] },
        "status": { "enum": ["current", "superseded", "withdrawn"] },
        "current": { "type": "boolean" },
        "supersedesTranscriptId": { "oneOf": [{ "type": "string", "pattern": "^trn_[a-f0-9]{64}$" }, { "type": "null" }] },
        "supersededByTranscriptId": { "oneOf": [{ "type": "string", "pattern": "^trn_[a-f0-9]{64}$" }, { "type": "null" }] }
      }
    },
    "sourceLifecycle": {
      "type": "object",
      "required": ["authority", "sourceEventId", "occurredAt", "reason"],
      "additionalProperties": false,
      "properties": {
        "authority": { "type": "string", "minLength": 1 },
        "sourceEventId": { "type": "string", "minLength": 1 },
        "occurredAt": { "type": "string", "format": "date-time" },
        "reason": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "eventType": { "const": "transcript.withdrawn" } } },
      "then": { "required": ["sourceLifecycle"] },
      "else": { "not": { "required": ["sourceLifecycle"] } }
    }
  ]
}
