{
  "name": "youtube2text",
  "version": "0.40.1",
  "description": "Local-first media transcription pipeline for YouTube and direct audio inputs.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "youtube2text": "dist/cli.js",
    "youtube2text-api": "dist/api.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli/index.ts",
    "dev:api": "tsx src/api/index.ts",
    "api": "node dist/api.js",
    "dev:web": "npm --prefix web run dev",
    "build:web": "npm --prefix web run build",
    "start:web": "npm --prefix web run start",
    "api:spec:validate": "redocly lint openapi.yaml",
    "api:types:generate": "openapi-typescript openapi.yaml -o web/lib/apiTypes.gen.ts",
    "api:contract:check": "node scripts/apiContractCheck.mjs",
    "naming:check": "node scripts/check-naming-contract.mjs",
    "version:check": "node scripts/versionCheck.mjs",
    "test:docker-smoke": "node scripts/dockerSmokeTest.mjs",
    "transcript:export-fixture": "node scripts/export-transcript-fixture.mjs",
    "transcript:fixture:check": "node scripts/validate-transcript-fixture.mjs",
    "test": "node --import tsx --test tests/all.test.ts"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "busboy": "^1.6.0",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "p-limit": "^7.3.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@redocly/cli": "^2.40.0",
    "@types/busboy": "^1.5.4",
    "@types/node": "^26.1.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
