# Required
# - AssemblyAI API key is required only when sttProvider=assemblyai.
# - Deepgram API key is required only when sttProvider=deepgram.
# - OpenAI API key is required only when sttProvider=openai_whisper.
ASSEMBLYAI_API_KEY=your-assemblyai_api_key
Y2T_ASSEMBLYAI_API_KEYS=key1,key2
DEEPGRAM_API_KEY=your-deepgram-api-key
Y2T_DEEPGRAM_API_KEYS=key1,key2
OPENAI_API_KEY=your-openai-api-key
Y2T_OPENAI_API_KEY=your-openai-api-key
Y2T_API_KEY=your-api-key
Y2T_WEB_AUTH_SECRET=replace-with-at-least-32-random-characters
Y2T_WEB_AUTH_PASSPHRASE=replace-with-a-strong-operator-passphrase
Y2T_WEB_AUTH_SESSION_HOURS=12
Y2T_STT_PROVIDER=assemblyai

# Optional: local dev only (allow API without key)
Y2T_ALLOW_INSECURE_NO_API_KEY=false
Y2T_ALLOW_INSECURE_NO_API_KEY_CONFIRM=I_UNDERSTAND

# Optional: CORS allowlist (comma-separated exact origins)
Y2T_CORS_ORIGINS=http://localhost:3000

# Optional: HTTP request body size limit (bytes)
Y2T_MAX_BODY_BYTES=1000000
# Optional: max upload size for POST /audio (MB)
Y2T_MAX_UPLOAD_MB=1024

# Optional: auth failure rate limit
Y2T_AUTH_FAIL_MAX=30
Y2T_AUTH_FAIL_WINDOW_MS=60000
Y2T_TRUST_PROXY=false
Y2T_TRUST_PROXY_IPS=
Y2T_API_KEY_MAX_BYTES=256
Y2T_API_KEY_MIN_BYTES=32

# Optional: webhook configuration
Y2T_WEBHOOK_ALLOWED_DOMAINS=example.com,sub.example.com
Y2T_WEBHOOK_MAX_AGE_SECONDS=0
Y2T_WEBHOOK_RETRIES=3
Y2T_WEBHOOK_TIMEOUT_MS=5000
Y2T_WEBHOOK_SECRET=your-webhook-secret

# Optional: durable Media Intake v1 and Transcript Ready v1.
# Keep delivery URL unset until Cortex reviews and freezes Transcript Ready v1.
Y2T_INTAKE_API_KEY=replace-with-at-least-32-random-characters
Y2T_INTAKE_ARTIFACT_ALLOWED_ORIGINS=https://media-source.example.com
Y2T_INTAKE_WORKER_ENABLED=true
Y2T_INTAKE_WORKER_INTERVAL_MS=1000
Y2T_INTAKE_LEASE_MS=300000
Y2T_INTAKE_FETCH_ATTEMPTS=5
Y2T_INTAKE_FETCH_TIMEOUT_MS=120000
Y2T_INTAKE_MAX_ARTIFACT_MB=2048
Y2T_INTAKE_TERMINAL_RETENTION_DAYS=365
Y2T_TRANSCRIPT_READY_URL=
Y2T_TRANSCRIPT_READY_SECRET=replace-with-at-least-32-random-characters
Y2T_OUTBOX_INTERVAL_MS=1000
Y2T_OUTBOX_MAX_ATTEMPTS=20
Y2T_OUTBOX_TIMEOUT_MS=10000
Y2T_OUTBOX_TERMINAL_RETENTION_DAYS=365

# Optional: SSE connection limit (0 disables)
Y2T_SSE_MAX_CLIENTS=1000
Y2T_SSE_MAX_CLIENTS_PER_IP=50
Y2T_SSE_MAX_LIFETIME_SECONDS=0
Y2T_MAX_BUFFERED_EVENTS_PER_RUN=5000
Y2T_MAX_EVENT_BYTES=65536

# Optional: write rate limits (POST/PATCH/DELETE endpoints)
Y2T_RATE_LIMIT_WRITE_MAX=60
Y2T_RATE_LIMIT_WINDOW_MS=60000

# Optional: read + health rate limits (GET endpoints)
Y2T_RATE_LIMIT_READ_MAX=300
Y2T_RATE_LIMIT_READ_WINDOW_MS=60000
Y2T_RATE_LIMIT_HEALTH_MAX=30
Y2T_RATE_LIMIT_HEALTH_WINDOW_MS=60000
Y2T_HEALTH_DEEP_PUBLIC=false

# Optional: global request timeout (ms, 0 disables)
Y2T_REQUEST_TIMEOUT_MS=30000
Y2T_UPLOAD_TIMEOUT_MS=120000
Y2T_MAX_CONCURRENT_RUNS_PER_KEY=0
Y2T_RUN_ALLOW_ANY_URL=false
Y2T_EXEC_MAX_BYTES=52428800

# Optional: run persistence
Y2T_API_PERSIST_RUNS=true
Y2T_API_PERSIST_DIR=output/_runs

# Optional: graceful shutdown timeout (seconds)
Y2T_SHUTDOWN_TIMEOUT_SECONDS=60

# Optional: retention cleanup (days, -1 disables)
Y2T_RETENTION_RUNS_DAYS=30
Y2T_RETENTION_AUDIO_DAYS=7

# Optional: scheduler / watchlist
Y2T_SCHEDULER_ENABLED=false
Y2T_SCHEDULER_INTERVAL_MINUTES=60
Y2T_SCHEDULER_MAX_CONCURRENT_RUNS=1
Y2T_WATCHLIST_ALLOW_ANY_URL=false

# Optional: provider-boundary usage ledger and hard economic limits.
# Enforcement and limits are env-only; 0 disables an individual limit.
Y2T_USAGE_ENFORCEMENT=enforce
Y2T_USAGE_MAX_ITEM_MINUTES=180
Y2T_USAGE_MAX_RUN_MINUTES=300
Y2T_USAGE_MAX_SOURCE_MINUTES_24H=600
Y2T_USAGE_MAX_TOTAL_MINUTES_30D=3000
Y2T_USAGE_MAX_TOTAL_USD_30D=25
Y2T_USAGE_RATE_ASSEMBLYAI_USD_PER_HOUR=0.23
Y2T_USAGE_RATE_DEEPGRAM_USD_PER_HOUR=0.552
Y2T_USAGE_RATE_OPENAI_WHISPER_USD_PER_HOUR=0.36

# Optional: yt-dlp
YT_DLP_PATH=your-yt_dlp_path

# Optional: health endpoint
Y2T_HEALTH_INCLUDE_PATHS=false

# Optional: OpenAI Whisper API
Y2T_OPENAI_WHISPER_MODEL=whisper-1

# Optional: Deepgram
Y2T_DEEPGRAM_MODEL=nova-3
Y2T_DEEPGRAM_DIARIZATION=true

# Optional: audio splitting limits
Y2T_MAX_AUDIO_MB=
Y2T_SPLIT_OVERLAP_SECONDS=2

# Optional: settings defaults (legacy env names still supported)
FILENAME_STYLE=title_id
ASSEMBLYAI_CREDITS_CHECK=warn
ASSEMBLYAI_MIN_BALANCE_MINUTES=60
COMMENTS_ENABLED=true
COMMENTS_MAX=100

# Optional: polling and retries
Y2T_POLL_INTERVAL_MS=5000
Y2T_MAX_POLL_MINUTES=60
Y2T_DOWNLOAD_RETRIES=2
Y2T_TRANSCRIPTION_RETRIES=2
Y2T_PROVIDER_TIMEOUT_MS=120000
Y2T_CATALOG_MAX_AGE_HOURS=168
Y2T_ASSEMBLYAI_KEY_FAILURES=2
Y2T_ASSEMBLYAI_KEY_COOLDOWN_MS=60000
Y2T_DEEPGRAM_KEY_FAILURES=2
Y2T_DEEPGRAM_KEY_COOLDOWN_MS=60000
